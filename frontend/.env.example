# Copy to .env.local for local overrides. Vite only exposes vars
# prefixed with VITE_.

# Defaults (auto-derived from window.location) work fine for local dev
# and for Docker Compose on the same host. Override if the backend is
# reachable at a different host/port.
# VITE_WS_URL=ws://localhost:8000/ws/telemetry
# VITE_API_URL=http://localhost:8000
